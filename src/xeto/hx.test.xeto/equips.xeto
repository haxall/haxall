EquipA : Ahu {
  attrs: Query {
    ElecAcVoltAttr { val: 24V }
    ManufacturerAttr { val: "Test"}
  }
  points: {
    ZoneAirTempSensor {
      ModbusAddr { addr: "16474", encoding: "s2", scale: "0.01" }
      BacnetAddr { addr: "AI3" }
    }
    ZoneAirHumiditySensor {
      ModbusAddr { addr: "16477", encoding: "u2", scale: "0.1" }
      BacnetAddr { addr: "AI4" }
    }
  }
}

EquipB : EquipA {
  points: {
    ZoneCo2Sensor {
      ModbusAddr { addr: "16478" }
      BacnetAddr { addr: "AI5" }
    }
  }
}

// multiple inheritance of points query: EquipWithPointsX and EquipWithPointsY
// each define a distinct point, and EquipXY combines both via And type

EquipWithPointsX : Equip {
  points: {
    ZoneAirTempSensor { BacnetAddr { addr: "AI1" } }
  }
}

EquipWithPointsY : Equip {
  points: {
    ZoneCo2Sensor { BacnetAddr { addr: "AI2" } }
  }
}

EquipXY : EquipWithPointsX & EquipWithPointsY

// multiple inheritance of points query where the spec also declares its own
// points: should union all three (X's, Y's, and own).  uses auto-named
// constraints since those exercise the remote loader's key/name divergence
EquipXYOwn : EquipWithPointsX & EquipWithPointsY {
  points: {
    DischargeAirTempSensor { BacnetAddr { addr: "AI3" } }
  }
}

// three-way merge of points query (merged pairwise), with and without an own
// points; own constraints order after all the supertype constraints
EquipWithPointsZ : Equip {
  points: {
    DischargeAirFlowSensor { BacnetAddr { addr: "AI6" } }
  }
}

Equip3 : EquipWithPointsX & EquipWithPointsY & EquipWithPointsZ

Equip3Own : EquipWithPointsX & EquipWithPointsY & EquipWithPointsZ {
  points: {
    DischargeAirTempSensor { BacnetAddr { addr: "AI3" } }
  }
}

// inheriting global thru multple inheritance paths:

ElecEquipA : Equip { elec }

ElecEquipB : Equip { elec }

ElecEquipSubB : ElecEquipB

ElecEquipAB : ElecEquipA & ElecEquipSubB

// makes the global elec optional, so its slot has own meta (maybe)
ElecEquipMaybeA : Equip { elec: Marker? }

// query traversal of systemRef which is MultiRef; the via and
// inverse queries must handle tag values of both Ref and Ref[]

EquipWithSystems : Equip {
  systems: Query<of:System, via:"systemRef+">  // Systems this equip is associated with
}

SystemWithEquips : System {
  equips: Query<of:Equip, inverse:"hx.test.xeto::EquipWithSystems.systems">  // Equips associated with this system
}

