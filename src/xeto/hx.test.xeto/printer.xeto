TestPrint: Dict {

  date1: Date?
  date2: Date?
  date3: Date?
  date4: Date?
  date5: Date?
  date6: Date?

  sv1: StatusVal?
  sv2: StatusVal?
  sn1: StatusNumber?
  sb1: StatusBool?
}

TestPrintA: TestPrint {
  date1: Date? "2026-04-20"
  date2: "2026-04-20"
  date3: <> "2026-04-20"
  date4: <metaQ> "2026-04-20"
  date5: <metaQ, metaStr:"src code">
  date6: <metaQ> // comment
}

TestPrintB: TestPrint {
  meta1: <metaStr:"">
  meta2: <metaStr:"foo bar">
  meta3: <metaQ, metaStr:"foo\nbar">

  <axon:---
  line 1
  line 2
  --->
}

TestPrintC: TestPrint {
  sv1: StatusNumber { val:"123" }
  sv2: <val:StatusNumber { val:"123" }>
}

TestPrintD: TestPrint {
  marker1
  marker2: Marker <admin>
  marker3: Marker?
  marker4: Marker? <admin>
  marker5: Marker? <axon:"foo\nbar">
}

