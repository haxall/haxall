TestPrint: Dict {

  date1: Date?
  date2: Date?
  date3: Date?
  date4: Date?
  date5: Date?
  date6: Date?
  date7: Date?

  sv1: StatusVal?
  sv2: StatusVal?
  sn1: StatusNumber?
  sb1: StatusBool?

  s1: Str?
  s2: Str?
  s3: Str?
  s4: Str?
  s5: Str?
}

TestPrintA: TestPrint {
  date1: Date? "2026-04-20"
  date2: Date "2026-04-20"
  date3: 2026-04-20
  date4: <> "2026-04-20"
  date5: <metaQ> "2026-04-20"
  date6: <metaQ, metaStr:"src code">
  date7: Date <metaQ> // comment
}

TestPrintB: TestPrint {
  meta1: <metaStr:"">
  meta2: <metaStr:"foo bar">
  meta3: <metaQ, metaStr:"foo\nbar">

  <axon:---
  line 1
  line 2
  --->
}

TestPrintC: TestPrint {
  sv1: StatusNumber { val:"123" }
  sv2: <val:StatusNumber { val:"123" }>
}

TestPrintD: TestPrint {
  marker1
  marker2: Marker <admin>
  marker3: Marker?
  marker4: Marker? <admin>
  marker5: Marker? <axon:"foo\nbar">
}

TestPrintE: TestPrint {
  s1: ""
  s2: 123
  s3: 123.4
  s4: 123.4gH₂O/kgAir
  s5: "123.4gH₂O/kgAir 123"
}

