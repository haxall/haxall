TestFolder : Comp {
}

TestAdd : Comp {
  in1: TestVal
  in2: TestVal
  out: TestVal <transient>
}

TestNumberAdd : Comp {
  in1: Number
  in2: Number
  out: Number <transient>
}

TestRamp : Comp {
  out: TestVal <transient>
}

TestCounter : Comp {
  out: TestVal <transient>
}

TestComposite : Comp {
  descr: "test descr"
  dur: Duration "5min"
  a: TestAdd {
     in1: {val:7}
     in2: {val:5}
  }
  nest: TestFolder {
    b: TestAdd {
       in1: {val:17}
       in2: {val:15}
    }
  }
}

TestFoo: Comp {
  a: Str "alpha"
  b: Str "beta"
  c: Str?
  methodEcho: Func { arg:Obj? }
  methodSquare: Func <axon:"a*a"> { a: Number, returns: Number }
  methodBad1: Func { arg: Str }
  methodBad2: Func { arg: Str }
  methodBad3: Func { arg: Str }
  methodBad4: Func { arg: Str }
  methodUpper: Func <axon:"""(""+x).upper"""> { x: Str, returns: Str }
  methodThis: Func <axon:"this"> { ignore: Str, returns: Obj }
}

TestVal : Dict {
  val: Number
  status: Str
}

TestAxonSquare : Comp {
  in: Number
  out: Number
  onExecute: Func <axon:"""do
      in: this.get("in")
      this.set("out", in*in)
    end
    """>
}

TestIncrement : Comp {
  in: Number
  out: Number
  onExecute: Func <axon:"""this.set("out",  this->in + 1)""">
}

TestPoint: Dict {
  x: Number
  y: Number
}

TestMixinComp: Comp
TestAndComp: TestIncrement & TestMixinComp

TestAxonComposite : Comp {
  in: Number
  out: Number <link:"b.out"> // this.out -> b.out

  str: Str "something here"
  point: TestPoint { x:12, y:34 }

  a: TestAxonSquare {
    in: Number <link:"in"> // this.in -> a.in
  }

  b: TestAxonSquare {
    in: Number <link:"a.out"> // a.out -> b.in
  }
}

TestDeep2Composite : Comp {
  topIn: Number
  sub1: TestAxonComposite
  topOut: Number <link:"folder.sub2.out">
  folder: Comp {
    sub2: TestAxonComposite
    sub3: TestDeep1Composite {
      in: Number <link:"topIn">
    }
  }
}

TestDeep1Composite : Comp {
  in: Number
  bar: Comp {
    qux: Comp {
      a: TestAxonSquare {
        in: Number <link:"in"> // this.in-> a.in
      }

      b: TestAxonSquare {
        in: Number <link:"bar.qux.a.out"> // a.out -> b.in
      }
    }
  }
}

//////////////////////////////////////////////////////////////////////////
// Remote loader handling covariant overrides
//////////////////////////////////////////////////////////////////////////

TestLabel : Comp {
  text: Str "label!"
  num: Number?
}

TestEdgeBox : Comp {
  center: Comp
}

TestEdgeBoxComposite: Comp {
  body: TestEdgeBox {
    center: TestLabel { num: "2001" }
  }
}

