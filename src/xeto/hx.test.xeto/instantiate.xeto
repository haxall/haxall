InstantiateA: {
  listRef: List<of:Ref>
  listRefNullable: List<of:Ref?>
  a: Str "alpha-a"
  b: Str? "bravo-a"
  c: Str?
  d: Str?
  icon: Ref?
  multiRef1: MultiRef?
  multiRef2: MultiRef?
}

InstantiateB: InstantiateA {
  a: "alpha-b"
  b: "bravo-b"
  c: "charlie-b"
  icon: @icon-b
  multiRef1: @icon-a
  multiRef2: { @icon-a, @icon-b }
}

InstantiateC: InstantiateB {
  d: "delta-c"
}

InstantiateD: {
  numA: Number 37
  numB: Number <val:37>
}

@icon-a: Dict {}
@icon-b: Dict {}

