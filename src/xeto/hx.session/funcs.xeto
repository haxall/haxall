+Funcs {

  sessionCountByUser: Func <nodoc, su> { returns: Grid }

  sessionDetails: Func <nodoc, su> { returns: Grid }

  sessionLogout: Func <nodoc, su, defMeta:{disKey:"ui::logout", select}> { sessionRefs: Obj?, returns: Obj? }

  sessions: Func <nodoc, su> { returns: Grid }

}